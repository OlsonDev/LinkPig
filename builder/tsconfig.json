{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "lib": ["ESNext"],
    "outDir": "./dist",
    "composite": true,
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "NodeNext"
  },
  "include": ["./**/*.ts", "../core/**/*.ts", "../dev/**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../core" }, { "path": "../dev" }]
}
