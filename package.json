{
  "name": "link-pig",
  "displayName": "Link Pig",
  "description": "Execute actions from `vscode://` URIs.",
  "version": "0.0.4",
  "license": "MIT",
  "repository": "github:OlsonDev/LinkPig",
  "publisher": "OlsonDev",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onUri"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "linkPig.copyLinkToFile",
        "title": "Link Pig: Copy Link to Clipboard"
      },
      {
        "command": "linkPig.copyLinkToFileLineColumn",
        "title": "Link Pig: Copy Link to Clipboard"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "linkPig.copyLinkToFile",
          "group": "6_copypath@100",
          "when": "!explorerResourceIsFolder"
        }
      ],
      "editor/title/context": [
        {
          "command": "linkPig.copyLinkToFile",
          "group": "1_cutcopypaste@100",
          "when": "resourceScheme == file || resourceScheme == vscode-webview"
        }
      ],
      "editor/context": [
        {
          "command": "linkPig.copyLinkToFileLineColumn",
          "group": "9_cutcopypaste@100"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run guard-dev && bun run package",
    "guard-dev": "node dev/guard.mjs",
    "compile": "bun build ./extension/extension.ts --outdir ./dist --target node --format cjs --sourcemap --external vscode --external path",
    "watch": "bun build ./extension/extension.ts --outdir ./dist --target node --format cjs --sourcemap --external vscode --external path --watch",
    "package": "bun build ./extension/extension.ts --outdir ./dist --target node --format cjs --sourcemap --minify --external vscode --external path",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "lint": "eslint extension",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "25.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.2.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
